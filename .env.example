# ELPROM — environment variables
# Set these in Cloudflare Pages → Settings → Environment Variables.
# NEVER commit real values. .env* is gitignored.

# --- Supabase (auth + database) ---
SUPABASE_URL=https://vgxalzfyygocyitqjqhi.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to browser

# --- LLM provider for managed (Pro) generation ---
GEMINI_API_KEY=your-gemini-api-key                # get from aistudio.google.com (starts with AIza...)

# --- Razorpay (Pro subscription payments) ---
RAZORPAY_KEY_ID=rzp_live_xxx                      # from Razorpay dashboard → Settings → API Keys
RAZORPAY_KEY_SECRET=your-key-secret               # server-side only
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret       # set when adding webhook in Razorpay dashboard
